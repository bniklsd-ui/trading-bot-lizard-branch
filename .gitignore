# ============================================================
# Trading Bot — .gitignore
# Rename this file from "gitignore.txt" to ".gitignore" after placing.
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.eggs/
build/
dist/
develop-eggs/
downloads/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
MANIFEST

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# --- Testing / Coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# --- Type checkers / linters ---
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.project
.pydevproject

# --- Jupyter ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# --- Secrets & credentials (HARD RULE) ---
# Credentials live in OS keyring ONLY. These patterns are a safety net.
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
credentials.json
config.local.*
**/secrets/
**/credentials/

# --- Runtime / Operational state ---
# State files are written by the bot, not source-controlled
ig_state.json
ig_config.json
turbo_candidates.json
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-wal
*.db-shm
# Phase 3 external-data cache (yFinance OHLCV JSON, written at runtime).
# Added 2026-06-02: the concept (§2) and phase3 CLAUDE.md assumed data/cache/
# was already ignored, but no rule covered it — reconciled here.
data/cache/
# Phase 4 LLM usage / cost log (token-meter records, written at runtime).
# Added 2026-06-08 (Step 5): the phase4 concept + CLAUDE.md flag this as a
# Step-5 must-do — the same reconciliation Phase 3 did for data/cache/. Only
# specific data/state/*.json files are ignored above (ig_state.json,
# turbo_candidates.json); the usage log wasn't covered, so add it here.
data/state/llm_usage.json
# Phase 5 execution state (write-ahead deal_reference / in-flight order records,
# written at runtime by the operator's live run). Added 2026-06-10 (Step 2): the
# same reconciliation Phase 3/4 did — only specific data/state/*.json files are
# ignored above; this operational idempotency store wasn't covered, so add it.
data/state/execution_state.json

# --- Logs ---
*.log
logs/
*.log.*

# --- Local config overrides ---
config.local.json
config.local.yml
*.local.toml

# --- OS junk ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# --- Build artifacts / temp ---
tmp/
temp/
*.tmp
*.bak
*.orig

# --- Project-specific output that shouldn't be committed ---
# Smoke test logs, debugging snapshots, etc.
smoke_test_output/
debug_snapshots/
